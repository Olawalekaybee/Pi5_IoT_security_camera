# Pi-Detect Environment Configuration
# Copy: cp .env.example .env
# Then edit .env with your actual values (never commit .env to git)

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
SECRET_KEY=change-me-in-production

# ── Camera ─────────────────────────────────────────────────────
# true  = PiCamera2 (Raspberry Pi hardware)
# false = OpenCV webcam (laptop development)
USE_PICAMERA=true
CAMERA_WIDTH=320
CAMERA_HEIGHT=240
CAMERA_FPS=30
WEBCAM_INDEX=0

# ── Detection ──────────────────────────────────────────────────
MODEL_NAME=yolov8n.pt
MODEL_PATH=models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
MAX_DETECTIONS=20
DETECTION_SKIP_FRAMES=10
DEVICE=cpu

# ── Streaming ──────────────────────────────────────────────────
STREAM_QUALITY=50
STREAM_MAX_FPS=12

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pi-detect.log
